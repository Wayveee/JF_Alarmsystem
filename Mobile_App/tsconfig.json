{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2021"],
    "moduleResolution": "node",
    "jsx": "react-native",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": false
  },
  "include": [
    "App.tsx",
    "app/**/*",
    "src/**/*",
    "types/**/*"
  ]
}
